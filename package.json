{
  "name": "music-desktop",
  "version": "1.0.0",
  "description": "Music desktop app (Electron + Node.js API)",
  "private": true,
  "scripts": {
    "dev:api": "cd music_api && npm run dev",
    "dev:app": "cd electron-app && npm run dev",
    "dev": "concurrently -n api,app -c blue,green \"npm run dev:api\" \"npm run dev:app\"",
    "install:api": "cd music_api && npm install",
    "install:app": "cd electron-app && npm install",
    "install:all": "npm run install:api && npm run install:app",
    "build": "cd electron-app && npm run build",
    "build:win": "cd electron-app && npm run build:win",
    "build:mac": "cd electron-app && npm run build:mac",
    "build:linux": "cd electron-app && npm run build:linux",
    "postinstall": "npm run install:all"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
